{
"compilerOptions": {
"moduleDetection": "force",
"target": "ES6",
// "module": "commonjs",
"module": "ESNext",
"rootDir": "./src",
"outDir": "./dist",
"esModuleInterop": true,
"forceConsistentCasingInFileNames": true,
"strict": true,
"skipLibCheck": true,
"moduleResolution": "bundler",
"lib": ["ESNext", "DOM"]
},
"include": ["src/**/*"],
"exclude": ["node_module", "dist"]
}
